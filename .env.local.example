# ============================================================================
# Local desktop deployment config (used by docker-compose.local.yml).
# The desktop installer GENERATES a `.env` from this template with strong random
# secrets and the detected LAN IP — a non-coder never edits it by hand.
#
# For manual local runs:  cp .env.local.example .env
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info

# --- Local admin seeded on first boot (AUTH_MODE is forced to jwt in compose) ---
ADMIN_EMAIL=admin@local.host
ADMIN_PASSWORD=admin123            # CHANGE on first login

# --- Secrets (installer generates strong random values) ---
JWT_SECRET=dev-jwt-secret-change-me-in-production-0001
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-me-in-prod-0002
DATABASE_PASSWORD=postgres
DATABASE_NAME=projectflow
DATABASE_USER=postgres

# --- LAN access (installer replaces localhost with the host PC's LAN IP) ---
# so team members' browsers on the office network can reach it.
FRONTEND_URL=http://localhost:3001
HRMS_FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Attendance rules (edit here, then Stop + Start the app to apply) ---
COMPANY_TIMEZONE=Asia/Kolkata
FULL_DAY_HOURS=9
HALF_DAY_HOURS=4
OFFICE_START_TIME=09:30

# --- Optional integrations (blank = feature off) ---
# OpenAI (AI features) is set here in .env only — there is no Settings-page field.
OPENAI_API_KEY=
# SMTP email can be set here OR in the in-app Settings page (Credential Settings).
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
