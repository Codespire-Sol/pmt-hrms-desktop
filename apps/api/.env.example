# Server Configuration
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Authentication mode: 'jwt' (local email/password — used by the desktop edition)
# or 'keycloak' (SSO). In 'jwt' mode the API issues its own tokens and seeds the
# admin below on first boot.
AUTH_MODE=jwt
ADMIN_EMAIL=admin@local.host
ADMIN_PASSWORD=admin123

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=projectflow
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# Prisma Database URL (constructed from above values)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/projectflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT signing secrets (use strong random values; the installer generates these)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Attendance rules
COMPANY_TIMEZONE=Asia/Kolkata
FULL_DAY_HOURS=9
HALF_DAY_HOURS=4
OFFICE_START_TIME=09:30

# Storage
UPLOAD_DIR=./uploads

# Frontend URLs
FRONTEND_URL=http://localhost:3001
HRMS_FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS — leave blank to keep the feature off.
# ---------------------------------------------------------------------------

# AI features (summaries, semantic search). Set your OpenAI key here.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Outbound email (SMTP). These can also be set in the in-app Settings page.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Google Cloud Storage for attachments (otherwise files are stored on local disk).
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Keycloak SSO — only needed when AUTH_MODE=keycloak (not used by the desktop edition).
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
