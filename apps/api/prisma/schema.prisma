  // Relations
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([documentType])
  @@map("employee_documents")
}

model Attendance {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId       String           @map("employee_id") @db.Uuid
  date             DateTime         @db.Date
  checkInTime      DateTime?        @map("check_in_time")
  checkOutTime     DateTime?        @map("check_out_time")
  status           AttendanceStatus
  leaveId          String?          @map("leave_id") @db.Uuid
  workHours        Decimal?         @map("work_hours") @db.Decimal(5, 2)
  manualCorrection Boolean          @default(false) @map("manual_correction")
  correctionReason String?          @map("correction_reason")
  correctedBy      String?          @map("corrected_by") @db.Uuid
  correctedAt      DateTime?        @map("corrected_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at")
  createdBy        String?          @map("created_by") @db.Uuid

  // Relations
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leave           Leave?           @relation(fields: [leaveId], references: [id], onDelete: SetNull)
  correctedByUser User?            @relation("AttendanceCorrectedBy", fields: [correctedBy], references: [id], onDelete: Restrict)
  createdByUser   User?            @relation("AttendanceCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  logs            AttendanceLog[]

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
  @@index([correctedBy])
  @@map("attendance")
}

model AttendanceLog {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  attendanceId   String   @map("attendance_id") @db.Uuid
  employeeId     String   @map("employee_id") @db.Uuid
  date           DateTime @db.Date
  type           String   // 'clock_in' | 'clock_out'
  loggedAt       DateTime @default(now()) @map("logged_at")
  createdAt      DateTime @default(now()) @map("created_at")
  latitude       Float?
  longitude      Float?
  accuracy       Float?
  source         String?  @default("manual") @db.VarChar(50)    // 'manual' | 'biometric' | 'biometric_cron' | 'simulate'
  deviceUserId   String?  @map("device_user_id") @db.VarChar(100)

  // Relations
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([attendanceId])
  @@index([employeeId, date])
  @@map("attendance_logs")
}

model Holiday {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  date        DateTime    @unique @db.Date
  name        String      @db.VarChar(200)
  type        HolidayType
