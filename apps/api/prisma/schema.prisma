  description String?
  status      NotificationSchemeStatus @default(active)
  isDefault   Boolean                  @default(false) @map("is_default")
  createdBy   String?                  @map("created_by") @db.Uuid
  updatedBy   String?                  @map("updated_by") @db.Uuid
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @default(now()) @updatedAt @map("updated_at")

  rules       NotificationSchemeRule[]
  assignments ProjectNotificationScheme[]

  @@index([projectId])
  @@index([status])
  @@map("notification_schemes")
}

model NotificationSchemeRule {
  id                   String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  notificationSchemeId String                  @map("notification_scheme_id") @db.Uuid
  eventType            NotificationRuleEvent   @map("event_type")
  recipientType        NotificationRecipientType @map("recipient_type")
  recipientId          String?                 @map("recipient_id") @db.VarChar(100)
  isEnabled            Boolean                 @default(true) @map("is_enabled")
  conditions           Json?                   @default("{}")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @default(now()) @updatedAt @map("updated_at")

  notificationScheme NotificationScheme @relation(fields: [notificationSchemeId], references: [id], onDelete: Cascade)

  @@index([notificationSchemeId])
  @@index([eventType, isEnabled])
  @@map("notification_scheme_rules")
}

model ProjectNotificationScheme {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId            String   @map("project_id") @db.Uuid
  notificationSchemeId String   @map("notification_scheme_id") @db.Uuid
  assignedBy           String?  @map("assigned_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at")

  notificationScheme NotificationScheme @relation(fields: [notificationSchemeId], references: [id], onDelete: Cascade)

  @@unique([projectId])
  @@index([notificationSchemeId])
  @@map("project_notification_schemes")
}

model UserGroup {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  createdBy   String?  @map("created_by") @db.Uuid
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  members             UserGroupMember[]
  roleBindings        GroupRoleBinding[]
  projectRoleBindings ProjectGroupRoleBinding[]

  @@index([projectId])
  @@unique([projectId, name])
  @@map("user_groups")
}

model UserGroupMember {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  addedBy   String?  @map("added_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("user_group_members")
}

model GroupRoleBinding {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  roleScope String   @default("pmt") @map("role_scope") @db.VarChar(20)
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, roleId, roleScope])
  @@index([groupId])
  @@index([roleId])
  @@map("group_role_bindings")
}

model ProjectGroupRoleBinding {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  groupId     String            @map("group_id") @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  projectRole ProjectMemberRole @map("project_role")
  createdBy   String?           @map("created_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, projectId])
  @@index([projectId, projectRole])
  @@map("project_group_role_bindings")
}


// ============================================================
// SAML SSO
// ============================================================

model SamlConfig {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// Human-readable label e.g. "Okta", "Azure AD"
  label                String    @db.VarChar(200)
  /// IdP SSO / entry-point URL
  entryPoint           String    @map("entry_point") @db.VarChar(1000)
  /// SP entity ID / issuer
  issuer               String    @db.VarChar(500)
  /// PEM-encoded X.509 certificate from IdP (for signature verification)
  idpCert              String    @map("idp_cert")
  /// ACS callback URL registered with the IdP
  callbackUrl          String    @map("callback_url") @db.VarChar(1000)
  /// JSON map of SAML attribute -> user field: { email, firstName, lastName, avatarUrl }
  attributeMapping     Json      @default("{}") @map("attribute_mapping")
  /// Email domain to enforce SSO on (e.g. "acme.com")
  enforceDomain        String?   @map("enforce_domain") @db.VarChar(255)
  isEnabled            Boolean   @default(false) @map("is_enabled")
  /// Auto-create users on first login (just-in-time provisioning)
  allowJitProvisioning Boolean   @default(true) @map("allow_jit_provisioning")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([isEnabled])
  @@index([enforceDomain])
  @@map("saml_configs")
}


// ============================================================
// CI/CD BUILD RUN MODELS
// ============================================================

model BuildRun {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId      String    @map("issue_id") @db.Uuid
  provider     String    @db.VarChar(20)   // "github" | "gitlab"
  runId        String    @map("run_id") @db.VarChar(100)
  pipelineName String    @map("pipeline_name") @db.VarChar(255)
  status       String    @db.VarChar(20)   // pending | running | success | failure | cancelled | skipped
  conclusion   String?   @db.VarChar(20)   // success | failure | neutral | cancelled | timed_out | action_required | skipped
  url          String    @db.VarChar(500)
  commitSha    String    @map("commit_sha") @db.VarChar(40)
  branchRef    String?   @map("branch_ref") @db.VarChar(255)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, provider, runId])
  @@index([issueId])
  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@map("build_runs")
}
