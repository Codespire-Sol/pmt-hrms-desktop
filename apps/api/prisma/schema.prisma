/// @trigger set_issue_number - auto-increments issue_number per project
/// @trigger update_issues_updated_at - auto-updates updated_at
/// @trigger issues_search_vector_update - maintains search_vector tsvector
model Issue {
  id                     String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId              String                   @map("project_id") @db.Uuid
  issueNumber            Int                      @map("issue_number")
  parentId               String?                  @map("parent_id") @db.Uuid
  typeId                 String                   @map("type_id") @db.Uuid
  statusId               String                   @map("status_id") @db.Uuid
  priorityId             String?                  @map("priority_id") @db.Uuid
  title                  String                   @db.VarChar(500)
  description            String?
  descriptionHtml        String?                  @map("description_html")
  reporterId             String                   @map("reporter_id") @db.Uuid
  assigneeId             String?                  @map("assignee_id") @db.Uuid
  sprintId               String?                  @map("sprint_id") @db.Uuid
  epicId                 String?                  @map("epic_id") @db.Uuid
  storyPoints            Int?                     @map("story_points")
  originalEstimateHours  Decimal?                 @map("original_estimate_hours") @db.Decimal(10, 2)
  remainingEstimateHours Decimal?                 @map("remaining_estimate_hours") @db.Decimal(10, 2)
  timeSpentHours         Decimal?                 @default(0) @map("time_spent_hours") @db.Decimal(10, 2)
  dueDate                DateTime?                @map("due_date") @db.Date
  startDate              DateTime?                @map("start_date") @db.Date
  resolution             String?                  @db.VarChar(100)
  resolutionDate         DateTime?                @map("resolution_date")
  environment            String?
  affectedVersion        String?                  @map("affected_version") @db.VarChar(50)
  fixVersion             String?                  @map("fix_version") @db.VarChar(50)
  components             String[]                 @default([])
  position               Int                      @default(0)
  commentCount           Int                      @default(0) @map("comment_count")
  attachmentCount        Int                      @default(0) @map("attachment_count")
  voteCount              Int                      @default(0) @map("vote_count")
  watcherCount           Int                      @default(0) @map("watcher_count")
  securityLevelId        String?                  @map("security_level_id") @db.Uuid
  searchVector           Unsupported("tsvector")? @map("search_vector")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @default(now()) @updatedAt @map("updated_at")
  deletedAt              DateTime?                @map("deleted_at")

  // Relations
  project                  Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent                   Issue?                    @relation("IssueParent", fields: [parentId], references: [id])
  children                 Issue[]                   @relation("IssueParent")
  type                     IssueType                 @relation(fields: [typeId], references: [id])
  status                   Status                    @relation(fields: [statusId], references: [id])
  priority                 IssuePriority?            @relation(fields: [priorityId], references: [id])
  reporter                 User                      @relation("IssueReporter", fields: [reporterId], references: [id])
  assignee                 User?                     @relation("IssueAssignee", fields: [assigneeId], references: [id])
  sprint                   Sprint?                   @relation(fields: [sprintId], references: [id])
  epic                     Epic?                     @relation(fields: [epicId], references: [id], onDelete: SetNull)
  securityLevel            SecurityLevel?            @relation(fields: [securityLevelId], references: [id])
  issueLabels              IssueLabel[]
  comments                 Comment[]
  attachments              Attachment[]
  watchers                 IssueWatcher[]
  votes                    IssueVote[]
  sourceLinks              IssueLink[]               @relation("SourceIssue")
  targetLinks              IssueLink[]               @relation("TargetIssue")
  history                  IssueHistory[]
  activityLogs             ActivityLog[]
  timeLogs                 TimeLog[]
  activeTimers             ActiveTimer[]
  notifications            Notification[]
  issueComponents          IssueComponent[]
  customFieldValues        IssueCustomFieldValue[]
  issueEmbedding           IssueEmbedding?
  dueDateReminders         DueDateReminder[]
  calendarEventMappings    CalendarEventMapping[]
  githubCommits            GithubCommit[]
  githubPullRequests       GithubPullRequest[]
  githubBranches           GithubBranch[]
  gitlabCommits            GitlabCommit[]
  gitlabMergeRequests      GitlabMergeRequest[]
  gitlabBranches           GitlabBranch[]
  buildRuns                BuildRun[]
  aiSuggestions            AiSuggestion[]
  aiFeedback               AiFeedback[]
  aiRecommendations        AiRecommendation[]
  timePredictions          TimePrediction[]
  automationExecutions     AutomationRuleExecution[] @relation("ExecutionTriggeredByIssue")
  issueTransitionApprovals IssueTransitionApproval[]
  wipLimitViolations       WipLimitViolation[]

  @@unique([projectId, issueNumber])
  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([statusId])
  @@index([typeId])
  @@index([parentId])
  @@index([sprintId])
  @@index([epicId])
  @@index([dueDate])
  @@index([priorityId])
  @@index([securityLevelId])
  @@map("issues")
}

