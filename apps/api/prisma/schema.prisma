// ProjectFlow API - Prisma Schema
// Migrated from Knex.js query builder

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum ProjectStatus {
  active
  archived
  on_hold
  completed

  @@map("project_status")
}

enum ProjectVisibility {
  private
  internal
  public

  @@map("project_visibility")
}

enum ProjectMemberRole {
  admin
  lead
  member
  viewer

  @@map("project_member_role")
}

// StatusCategory enum removed — category is now a free-form VARCHAR(50)
// Default built-in categories: todo, in_progress, in_review, done

enum SprintStatus {
  planned
  active
  completed
  cancelled

  @@map("sprint_status")
}

enum IssueLinkType {
  blocks
  is_blocked_by
  duplicates
  is_duplicated_by
  relates_to
  causes
  is_caused_by
  clones
  is_cloned_by

  @@map("issue_link_type")
}

enum IssueChangeType {
  create
  update
  delete

  @@map("issue_change_type")
}

enum CustomFieldType {
  text
  number
  date
  datetime
  select
  multiselect
  checkbox
  url
  email
  user

  @@map("custom_field_type")
}

enum DashboardType {
  user
  project

  @@map("dashboard_type")
}

enum DashboardPermission {
  view
  edit

  @@map("dashboard_permission")
}

enum SavedFilterVisibility {
  private
  project
  global

  @@map("saved_filter_visibility")
}

enum ScreenOperation {
  create
  view
  edit
  transition

  @@map("screen_operation")
}

enum WipLimitType {
  soft
  hard

  @@map("wip_limit_type")
}

enum WebhookMethod {
  GET
  POST
  PUT
  PATCH
  DELETE

  @@map("webhook_method")
}

enum WebhookDeliveryStatus {
  pending
  success
  failed
  retrying

  @@map("webhook_delivery_status")
}

enum WebhookPayloadFormat {
  json
  form

  @@map("webhook_payload_format")
}

enum AutomationTriggerType {
  issue_created
  issue_updated
  issue_transitioned
  issue_assigned
  issue_commented
  sprint_started
  sprint_completed
  scheduled
  manual

  @@map("automation_trigger_type")
}

enum AutomationExecutionStatus {
  pending
  running
  success
  failure
  skipped

  @@map("automation_execution_status")
}

enum TransitionConditionType {
  required_fields
  field_value
  permission
  assignee
  reporter
  resolution
  custom_script
  linked_issues
  subtasks_done
  time_logged
  approval
  project_role

  @@map("transition_condition_type")
}

enum TransitionValidatorType {
  validate_regex
  validate_date_range
  validate_numeric_range
  validate_email
  validate_url
  validate_custom

  @@map("transition_validator_type")
}

enum TransitionPostfunctionType {
  set_field
  copy_field
  clear_field
  assign_to_reporter
  assign_to_lead
  unassign
  add_comment
  add_watcher
  send_notification
  update_parent
  trigger_webhook

  @@map("transition_postfunction_type")
}

enum ApprovalDecision {
  approved
  rejected

  @@map("approval_decision")
}

enum IssueTransitionApprovalStatus {
  pending
  approved
  rejected
  expired

  @@map("issue_transition_approval_status")
}

enum VersionStatus {
  unreleased
  released
  archived

  @@map("version_status")
}

enum EpicStatus {
  to_do
  in_progress
  done

  @@map("epic_status")
}

enum WipViolationAction {
  override
  blocked

  @@map("wip_violation_action")
}

enum RecentItemEntityType {
  issue
  project
  user
  comment

  @@map("recent_item_entity_type")
}

enum ScreenTabFieldType {
  system
  custom

  @@map("screen_tab_field_type")
}

enum EmployeeStatus {
  onboarding
  active
  notice_period
  exited
  deleted

  @@map("employee_status")
}

enum EmployeeMaritalStatus {
  single
  married
  divorced
  widowed

  @@map("employee_marital_status")
}

enum Gender {
  male
  female
  other

  @@map("gender")
}

enum AttendanceStatus {
  checked_in
  present
  absent
  half_day
  incomplete
  on_leave
  holiday

  @@map("attendance_status")
}

enum HolidayType {
  national
  regional
  company
  optional

  @@map("holiday_type")
}

enum LeaveType {
  casual
  sick
  earned
  lop

  @@map("leave_type")
}

enum LeaveSession {
  full_day
  first_half
  second_half

  @@map("leave_session")
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled

  @@map("leave_status")
}

enum PayrollStatus {
  draft
  generated
  finalized

  @@map("payroll_status")
}

enum OnboardingStatus {
  in_progress
  completed

  @@map("onboarding_status")
}

enum OffboardingStatus {
  in_progress
  completed

  @@map("offboarding_status")
}

enum OffboardingReason {
  resignation
  termination
  end_of_contract
  other

  @@map("offboarding_reason")
}

enum ApprovalResourceType {
  leave
  attendance_correction
  profile_change

  @@map("approval_resource_type")
}

enum ApprovalApproverType {
  manager
  hr
  admin

  @@map("approval_approver_type")
}

enum ApprovalStatus {
  pending
  approved
  rejected
  cancelled
  escalated

  @@map("approval_status")
}

enum ApprovalPriority {
  low
  normal
  high
  urgent

  @@map("approval_priority")
}

enum ApprovalResponse {
  approved
  rejected
  delegated

  @@map("approval_response")
}

// ============================================================
// CORE MODELS
// ============================================================

model User {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email               String    @unique @db.VarChar(255)
  passwordHash        String?   @map("password_hash") @db.VarChar(255)
  firstName           String    @map("first_name") @db.VarChar(100)
  lastName            String    @map("last_name") @db.VarChar(100)
  avatarUrl           String?   @map("avatar_url") @db.VarChar(500)
  phone               String?   @db.VarChar(20)
  timezone            String?   @default("UTC") @db.VarChar(50)
  locale              String?   @default("en") @db.VarChar(10)
  isActive            Boolean   @default(true) @map("is_active")
  isVerified          Boolean   @default(false) @map("is_verified")
  emailVerifiedAt     DateTime? @map("email_verified_at")
  lastLoginAt         DateTime? @map("last_login_at")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  passwordChangedAt   DateTime? @map("password_changed_at")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?   @map("two_factor_secret") @db.VarChar(255)
  keycloakSub         String?   @unique @map("keycloak_sub") @db.VarChar(255)
  roleId              String?   @map("role_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  // Relations
  role                       Role?                             @relation(fields: [roleId], references: [id])
  ownedProjects              Project[]                         @relation("ProjectOwner")
  leadProjects               Project[]                         @relation("ProjectLead")
  defaultAssigneeProjects    Project[]                         @relation("ProjectDefaultAssignee")
  projectMemberships         ProjectMember[]
  invitedMembers             ProjectMember[]                   @relation("InvitedBy")
  reportedIssues             Issue[]                           @relation("IssueReporter")
  assignedIssues             Issue[]                           @relation("IssueAssignee")
  comments                   Comment[]
  attachments                Attachment[]
  notifications              Notification[]
  actedNotifications         Notification[]                    @relation("NotificationActor")
  refreshTokens              RefreshToken[]
  timeLogs                   TimeLog[]
  activeTimer                ActiveTimer?
  issueWatchers              IssueWatcher[]
  issueVotes                 IssueVote[]
  issueLabelsAdded           IssueLabel[]
  issueHistory               IssueHistory[]
  activityLogs               ActivityLog[]
  commentReactions           CommentReaction[]
  auditLogs                  AuditLog[]
  createdSprints             Sprint[]                          @relation("SprintCreatedBy")
  completedSprints           Sprint[]                          @relation("SprintCompletedBy")
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  oauthProviders             OauthProvider[]
  twoFactorBackupCodes       TwoFactorBackupCode[]
  notificationPreferences    NotificationPreference[]
  pushSubscriptions          PushSubscription[]
  savedFilters               SavedFilter[]
  filterSubscriptions        FilterSubscription[]
  dashboardPreferences       DashboardPreference[]
  dashboardSharesCreated     DashboardShare[]                  @relation("ShareCreatedBy")
  dashboardSharesReceived    DashboardShare[]                  @relation("ShareUser")
  scheduledReports           ScheduledReport[]
  customFieldValues          IssueCustomFieldValue[]
  userSkills                 UserSkill[]
  timePredictions            TimePrediction[]
  aiRecommendationsActed     AiRecommendation[]                @relation("RecommendationActedBy")
  aiFeedback                 AiFeedback[]
  aiRequestLogs              AiRequestLog[]
  aiUsage                    AiUsage[]
  automationRules            AutomationRule[]
  automationExecutions       AutomationRuleExecution[]         @relation("ExecutionTriggeredByUser")
  webhooksCreated            Webhook[]
  slackInstallations         SlackWorkspace[]
  slackUserMappings          SlackUserMapping[]
  githubConnection           GithubConnection?
  gitlabConnection           GitlabConnection?
  calendarIntegrations       CalendarIntegration[]
  calendarEventMappings      CalendarEventMapping[]
  dueDateReminders           DueDateReminder[]
  recentItems                RecentItem[]
  searchHistory              SearchHistory[]
  savedSearches              SavedSearch[]
  issueLinkCreator           IssueLink[]
  issueTransitionRequests    IssueTransitionApproval[]         @relation("TransitionRequestedBy")
  approvalResponses          IssueTransitionApprovalResponse[]
  wipLimitViolations         WipLimitViolation[]
  aiSuggestions              AiSuggestion[]
  commentMentions            CommentMention[]
  resourceRates              ResourceRate[]
  employee                   Employee?                         @relation("EmployeeUser")
  employeesCreated           Employee[]                        @relation("EmployeeCreatedBy")
  employeesUpdated           Employee[]                        @relation("EmployeeUpdatedBy")
  employeesDeleted           Employee[]                        @relation("EmployeeDeletedBy")
  attendanceCorrections      Attendance[]                      @relation("AttendanceCorrectedBy")
  attendanceCreated          Attendance[]                      @relation("AttendanceCreatedBy")
  holidaysCreated            Holiday[]                         @relation("HolidayCreatedBy")
  holidaysUpdated            Holiday[]                         @relation("HolidayUpdatedBy")
  leaveApprovals             Leave[]                           @relation("LeaveApprovedBy")
  leaveRejections            Leave[]                           @relation("LeaveRejectedBy")
  payrollUploads             Payroll[]                         @relation("PayrollUploadedBy")
  payrollFinalizations       Payroll[]                         @relation("PayrollFinalizedBy")
  payrollLocks               PayrollLock[]                     @relation("PayrollLockedBy")
  onboardingCompletions      Onboarding[]                      @relation("OnboardingCompletedBy")
  onboardingTaskCompletions  OnboardingTask[]                  @relation("OnboardingTaskCompletedBy")
  offboardingInitiations     Offboarding[]                     @relation("OffboardingInitiatedBy")
  offboardingCompletions     Offboarding[]                     @relation("OffboardingCompletedBy")
  offboardingTaskCompletions OffboardingTask[]                 @relation("OffboardingTaskCompletedBy")
  approvalsAssigned          Approval[]                        @relation("ApprovalApprover")
  approvalsCurrentlyAssigned Approval[]                        @relation("ApprovalCurrentApprover")
  approvalHistoryActions     ApprovalHistory[]                 @relation("ApprovalHistoryActedBy")
  systemSettingsUpdated      SystemSetting[]                   @relation("SystemSettingUpdatedBy")
  createdEpics               Epic[]                            @relation("EpicCreator")
  pagesCreated               Page[]                            @relation("PageCreatedBy")
  userGroupMemberships       UserGroupMember[]
  userPermissions            UserPermission[]
  grantedPermissions         UserPermission[]  @relation("UserPermissionGranter")

  @@index([isActive])
  @@index([deletedAt])
  @@index([roleId])
  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(50)
  displayName String   @map("display_name") @db.VarChar(100)
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  level       Int      @default(0)
  /// Which app created this custom role: 'hrms' | 'pmt' | null (null = system/global)
  app         String?  @db.VarChar(10)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  users              User[]
  rolePermissions    RolePermission[]
  securityLevelRoles SecurityLevelRole[]

  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String  @unique @db.VarChar(100)
  displayName String  @map("display_name") @db.VarChar(200)
  description String?
  resource    String  @db.VarChar(50)
  action      String  @db.VarChar(50)
  /// Which application owns this permission: 'hrms' | 'pmt' | 'global'
  app         String  @default("pmt") @db.VarChar(20)

  // Relations
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([resource, action])
  @@index([app])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedBy    String?  @map("granted_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granter    User?      @relation("UserPermissionGranter", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

// ============================================================
// PROJECT MODELS
// ============================================================

model Project {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key               String            @unique @db.VarChar(10)
  name              String            @db.VarChar(200)
  description       String?
  ownerId           String            @map("owner_id") @db.Uuid
  leadId            String?           @map("lead_id") @db.Uuid
  categoryId        String?           @map("category_id") @db.Uuid
  category          String?           @db.VarChar(100)
  status            ProjectStatus     @default(active)
  visibility        ProjectVisibility @default(private)
  startDate         DateTime?         @map("start_date") @db.Date
  targetEndDate     DateTime?         @map("target_end_date") @db.Date
  actualEndDate     DateTime?         @map("actual_end_date") @db.Date
  defaultAssigneeId String?           @map("default_assignee_id") @db.Uuid
  settings          Json?             @default("{}")
  metadata          Json?             @default("{}")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  // Relations
  owner                  User                    @relation("ProjectOwner", fields: [ownerId], references: [id])
  lead                   User?                   @relation("ProjectLead", fields: [leadId], references: [id])
  defaultAssignee        User?                   @relation("ProjectDefaultAssignee", fields: [defaultAssigneeId], references: [id])
  projectCategory        ProjectCategory?        @relation(fields: [categoryId], references: [id])
  members                ProjectMember[]
  issues                 Issue[]
  sprints                Sprint[]
  workflows              Workflow[]
  issueTypes             IssueType[]
  labels                 Label[]
  components             Component[]
  versions               Version[]
  epics                  Epic[]
  boards                 Board[]
  customFields           CustomField[]
  automationRules        AutomationRule[]
  webhooks               Webhook[]
  notifications          Notification[]
  activityLogs           ActivityLog[]
  securityLevels         SecurityLevel[]
  screens                Screen[]
  screenSchemes          ScreenScheme[]
  issueTypeScreenSchemes IssueTypeScreenScheme[]
  scheduledReports       ScheduledReport[]
  aiProjectConfig        AiProjectConfig?
  aiRequestLogs          AiRequestLog[]
  aiFeedback             AiFeedback[]
  aiUsage                AiUsage[]
  aiRecommendations      AiRecommendation[]
  slackWorkspace         SlackWorkspace?
  githubRepository       GithubRepository?
  gitlabRepository       GitlabRepository?
  templates              ProjectTemplate[]
  savedFilters           SavedFilter[]
  pages                  Page[]
  budget                 ProjectBudget?
  resourceRates          ResourceRate[]
  budgetAlerts           BudgetAlert[]

  @@index([ownerId])
  @@index([status])
  @@index([categoryId])
  @@map("projects")
}

model ProjectMember {
  id        String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId String            @map("project_id") @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  role      ProjectMemberRole @default(member)
  joinedAt  DateTime          @default(now()) @map("joined_at")
  invitedBy String?           @map("invited_by") @db.Uuid

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviter User?   @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model ProjectCategory {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?
  color       String?  @db.VarChar(7)
  icon        String?  @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  projects Project[]

  @@map("project_categories")
}

model ProjectTemplate {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  projectId   String   @map("project_id") @db.Uuid
  config      Json     @default("{}")
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_templates")
}

// ============================================================
// FINANCIAL MODELS
// ============================================================

model ProjectBudget {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId        String   @unique @map("project_id") @db.Uuid
  totalBudget      Decimal  @map("total_budget") @db.Decimal(12, 2)
  currency         String   @default("USD") @db.VarChar(10)
  alertThreshold   Decimal  @default(0.80) @map("alert_threshold") @db.Decimal(3, 2)
  warningThreshold Decimal  @default(0.90) @map("warning_threshold") @db.Decimal(3, 2)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_budgets")
}

model ResourceRate {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId     String    @map("project_id") @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  role          String    @db.VarChar(100)
  hourlyRate    Decimal   @map("hourly_rate") @db.Decimal(10, 2)
  currency      String    @default("USD") @db.VarChar(10)
  effectiveFrom DateTime  @default(now()) @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@map("resource_rates")
}

model BudgetAlert {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  alertType        String   @map("alert_type") @db.VarChar(50)
  thresholdPercent Decimal  @map("threshold_percent") @db.Decimal(5, 2)
  currentSpend     Decimal  @map("current_spend") @db.Decimal(12, 2)
  totalBudget      Decimal  @map("total_budget") @db.Decimal(12, 2)
  triggeredAt      DateTime @default(now()) @map("triggered_at")
  isRead           Boolean  @default(false) @map("is_read")
  metadata         Json     @default("{}")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isRead])
  @@map("budget_alerts")
}

// ============================================================
// WORKFLOW MODELS
// ============================================================

model Workflow {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statuses    Status[]
  transitions StatusTransition[]

  @@index([projectId])
  @@map("workflows")
}

model Status {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowId  String         @map("workflow_id") @db.Uuid
  name        String         @db.VarChar(50)
  displayName String         @map("display_name") @db.VarChar(100)
  description String?
  color       String?        @db.VarChar(7)
  category    String         @default("todo") @db.VarChar(50)
  position    Int            @default(0)
  isInitial   Boolean        @default(false) @map("is_initial")
  isFinal     Boolean        @default(false) @map("is_final")
  wipLimit    Int?           @map("wip_limit")
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  workflow           Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  issues             Issue[]
  transitionsFrom    StatusTransition[] @relation("TransitionFrom")
  transitionsTo      StatusTransition[] @relation("TransitionTo")
  boardColumns       BoardColumn[]
  githubRepositories GithubRepository[]

  @@unique([workflowId, name])
  @@index([workflowId])
  @@map("statuses")
}

model StatusTransition {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workflowId   String  @map("workflow_id") @db.Uuid
  fromStatusId String  @map("from_status_id") @db.Uuid
  toStatusId   String  @map("to_status_id") @db.Uuid
  name         String? @db.VarChar(100)

  // Relations
  workflow       Workflow                         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStatus     Status                           @relation("TransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus       Status                           @relation("TransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade)
  conditions     WorkflowTransitionCondition[]
  validators     WorkflowTransitionValidator[]
  postfunctions  WorkflowTransitionPostfunction[]
  approvalConfig WorkflowTransitionApproval?
  issueApprovals IssueTransitionApproval[]

  @@unique([workflowId, fromStatusId, toStatusId])
  @@map("status_transitions")
}

model IssueType {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  name        String   @db.VarChar(50)
  displayName String   @map("display_name") @db.VarChar(100)
  description String?
