<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime entitlements for PMT-HRMS.

    The app spawns a bundled Node backend (resources/api/dist/index.js) and a
    bundled Postgres server (embedded-postgres) as child processes, and serves
    the web UIs over a local HTTP port. These entitlements permit that under the
    hardened runtime (required for notarization).
  -->

  <!-- Electron / V8 JIT needs writable+executable memory. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Some bundled native modules / the Node runtime use unsigned exec memory. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Allow loading the bundled Node/Postgres binaries and native .node modules
       that are not signed by us (e.g. the embedded-postgres binaries). -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Allow the DYLD environment used to launch bundled child processes. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- Outbound connections (the renderer/app talking to the local API, and any
       external services the API calls). -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Inbound connections: the bundled API + Postgres listen on localhost. -->
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
