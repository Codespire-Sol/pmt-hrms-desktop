# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# --- Electron desktop: build artifacts (regenerated by CI — never commit) ---
electron-app/resources/
electron-app/release/
# electron-app/build/ is a SOURCE config dir (entitlements + icon readme); the
# global `build/` rule above would hide it, so re-include the folder and then
# re-ignore only the generated icons (CI regenerates them via make-icons.js).
!electron-app/build/
electron-app/build/icon.png
electron-app/build/icon.ico
electron-app/build/icon.icns

# Environment & secrets — NEVER commit real values
# (.env is generated by the installer with real secrets; only templates are tracked)
.env
.env.*
!.env.local.example
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
gcp-service-account.json

# Logs
*.log
logs/
npm-debug.log*

# Test / coverage artifacts
coverage/
.nyc_output/
junit.xml

# Uploaded files (runtime data)
apps/api/uploads/*
!apps/api/uploads/.gitkeep

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Local Claude / AI tool state
.claude/
